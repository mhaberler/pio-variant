{
  "build": {
    "arduino": {
      "ldscript": "esp32p4_out.ld"
    },
    "core":         "esp32",
    "extra_flags":  "-DARDUINO_ESP32_P4_WIFI6 -DARDUINO_ARCH_ESP32 -DARDUINO_USB_MODE=1",
    "f_cpu":        "360000000L",
    "f_flash":      "80000000L",
    "flash_mode":   "qio",
    "mcu":          "esp32p4",
    "variant":      "esp32_p4_wifi6",
    "variants_dir": "variants"
  },
  "connectivity": ["wifi", "bluetooth"],
  "debug": {
    "openocd_target": "esp32p4.cfg"
  },
  "frameworks": ["arduino", "espidf"],
  "name": "ESP32-P4-WIFI6 (with ESP32-C6 Wi-Fi 6 co-processor)",
  "upload": {
    "flash_size":          "16MB",
    "maximum_ram_size":    32768000,
    "maximum_size":        16777216,
    "require_upload_port": true,
    "speed":               921600
  },
  "url":    "https://docs.waveshare.com/ESP32-P4-WIFI6#pinout-definition",
  "vendor": "Espressif"
}
